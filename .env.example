# =============================================================================
# VARIÁVEIS DE AMBIENTE — Dashboard Criminalidade
# =============================================================================
# Copie este arquivo para ".env" e preencha com os valores reais.
# NUNCA commite o arquivo ".env" com credenciais reais.
# =============================================================================

# --- Banco de Dados (PostgreSQL) ---
# Formato: postgresql://<usuario>:<senha>@<host>:<porta>/<nome_do_banco>
DATABASE_URL=postgresql://seu_usuario:sua_senha@localhost:5432/ssp_dashboard

# --- API: Política de CORS ---
# Lista de origens permitidas, separadas por vírgula.
# Em desenvolvimento, use http://localhost:5173 (Vite dev server).
# Em produção, liste APENAS os domínios confiáveis da sua aplicação.
# Exemplo produção: CORS_ORIGINS=https://dashboard.seudominio.com.br
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Ambiente da aplicação ---
# "development" | "production"
APP_ENV=development
